load("@rules_img//img:image.bzl", "image_from_binary")
load("@rules_img//img:push.bzl", "image_push")

image_from_binary(
    name = "image",
    base = "@ubuntu",
    binary = "//:hello_world_app",
    platforms = [
        "//platform:linux_amd64",
        "//platform:linux_arm64",
    ],
)

image_push(
    name = "push",
    image = ":image",
    registry = "ghcr.io",
    repository = "malt3/rules_img/python",
    tag = "image_from_binary_example",
    visibility = ["//:__pkg__"],
)
