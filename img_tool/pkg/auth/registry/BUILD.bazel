        "@com_github_google_go_containerregistry//pkg/v1/google",
        "@com_github_google_go_containerregistry//pkg/v1/remote",
    ],
)

go_test(
    name = "registry_test",
    size = "small",
    srcs = [
        "inline_config_test.go",
        "registry_test.go",
    ],
    embed = [":registry"],
    deps = [
        "@com_github_google_go_containerregistry//pkg/name",
    ],
