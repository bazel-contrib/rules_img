load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

bzl_library(
    name = "layer_helper",
    srcs = ["layer_helper.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [
        ":build",
        "//img:providers",
        "@bazel_skylib//rules:common_settings",
    ],
)

bzl_library(
    name = "write_index_json",
    srcs = ["write_index_json.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [":build"],
)

filegroup(
    name = "all_files",
    srcs = glob(["**"]),
    visibility = ["//img/private/release:__subpackages__"],
)

bzl_library(
    name = "layer_attrs",
    srcs = ["layer_attrs.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = ["@bazel_skylib//rules:common_settings"],
)

bzl_library(
    name = "deploy_attrs",
    srcs = ["deploy_attrs.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [
        "//img/private/providers:deploy_info",
        "//img/private/providers:index_info",
        "//img/private/providers:load_settings_info",
        "//img/private/providers:manifest_info",
        "//img/private/providers:push_settings_info",
        "//img/private/providers:signing_config_info",
        "//img/private/providers:stamp_setting_info",
        "@bazel_skylib//rules:common_settings",
    ],
)

bzl_library(
    name = "deploy_helpers",
    srcs = ["deploy_helpers.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [
        "//img/private/providers:deploy_info",
        "//img/private/providers:index_info",
        "//img/private/providers:load_settings_info",
        "//img/private/providers:manifest_info",
        "//img/private/providers:push_settings_info",
        "//img/private/providers:signing_config_info",
        "@bazel_skylib//rules:common_settings",
    ],
)

bzl_library(
    name = "sparse_oci_layout",
    srcs = ["sparse_oci_layout.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [":build"],
)

bzl_library(
    name = "tar_layer",
    srcs = ["tar_layer.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [
        ":build",
        ":layer_helper",
        "//img/private/providers:layers_info",
        "//img/private/providers:single_layer_info",
        "@bazel_skylib//lib:paths",
        "@bazel_skylib//rules:common_settings",
    ],
)

bzl_library(
    name = "build",
    srcs = ["build.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "default_deploy_tool",
    srcs = ["default_deploy_tool.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "inherit",
    srcs = ["inherit.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "media_types",
    srcs = ["media_types.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "transitions",
    srcs = ["transitions.bzl"],
    visibility = ["//img:__subpackages__"],
)
