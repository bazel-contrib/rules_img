load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

bzl_library(
    name = "layer_helper",
    srcs = ["layer_helper.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = ["//img:providers"],
)

bzl_library(
    name = "write_index_json",
    srcs = ["write_index_json.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [":build"],
)

filegroup(
    name = "all_files",
    srcs = glob(["**"]),
    visibility = ["//img/private/release:__subpackages__"],
)

bzl_library(
    name = "build",
    srcs = ["build.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "media_types",
    srcs = ["media_types.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "transitions",
    srcs = ["transitions.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "default_deploy_tool",
    srcs = ["default_deploy_tool.bzl"],
    visibility = ["//img:__subpackages__"],
)

bzl_library(
    name = "layer_attrs",
    srcs = ["layer_attrs.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = ["@bazel_skylib//rules:common_settings"],
)

bzl_library(
    name = "tar_layer",
    srcs = ["tar_layer.bzl"],
    visibility = ["//img:__subpackages__"],
    deps = [
        ":build",
        ":layer_helper",
        "//img/private/providers:layers_info",
        "//img/private/providers:single_layer_info",
        "@bazel_skylib//rules:common_settings",
    ],
)
