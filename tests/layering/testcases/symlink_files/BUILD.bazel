load("@rules_img//img:layer.bzl", "image_layer")
load("//tests/layering:defs.bzl", "layer_contents_test")

# gazelle:exclude_from_release

# A native (declare_symlink) symlink and a regular file carried through
# DefaultInfo into a layer.
image_layer(
    name = "layer",
    srcs = {
        "/opt/pkg": "//tests/layering/testcases:symlink_files",
    },
)

layer_contents_test(
    name = "test",
    size = "small",
    layer = ":layer",
    manifests = ["expected.ndjson"],
    # Native unresolved symlinks (declare_symlink) materialize with absolute
    # host paths on Windows, so the recorded relative linkname is Unix-only.
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)
