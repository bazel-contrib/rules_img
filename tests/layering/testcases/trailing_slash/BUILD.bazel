load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_img//img:layer.bzl", "image_layer")
load("//tests/layering:defs.bzl", "layer_contents_test")

# gazelle:exclude_from_release

write_file(
    name = "a",
    out = "a.txt",
    content = ["a\n"],
)

write_file(
    name = "b",
    out = "nested/b.txt",
    content = ["b\n"],
)

filegroup(
    name = "files",
    srcs = [
        ":a",
        ":b",
    ],
)

# A srcs key ending in "/" is accepted and normalized by the placement math (no
# doubled slash); the multi-output target is placed package-relative beneath it.
image_layer(
    name = "layer",
    srcs = {
        "/opt/data/": ":files",
    },
)

layer_contents_test(
    name = "test",
    size = "small",
    layer = ":layer",
    manifests = ["expected.ndjson"],
)
