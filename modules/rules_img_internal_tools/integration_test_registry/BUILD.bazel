load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "integration_test_registry_lib",
    srcs = ["main.go"],
    importpath = "github.com/bazel-contrib/rules_img/modules/rules_img_internal_tools/integration_test_registry",
    visibility = ["//visibility:private"],
    deps = ["@rules_img_tool//pkg/registry"],
)

go_binary(
    name = "integration_test_registry",
    embed = [":integration_test_registry_lib"],
    pure = "on",
    visibility = ["//visibility:public"],
)

build_test(
    name = "test",
    targets = [":integration_test_registry"],
)
